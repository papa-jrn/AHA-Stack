---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <header
    class="border-b border-zinc-200 bg-white/80 backdrop-blur dark:border-zinc-800 dark:bg-zinc-950/80"
  >
    <div
      class="mx-auto flex h-14 max-w-3xl items-center justify-between px-4"
    >
      <span class="text-sm font-semibold tracking-tight">AHA Stack</span>
      <nav class="flex gap-4 text-sm font-medium">
        <a
          href="/login"
          class="text-zinc-600 transition hover:text-foreground dark:text-zinc-400"
          >Sign in</a
        >
        <a
          href="/account"
          class="text-zinc-600 transition hover:text-foreground dark:text-zinc-400"
          >Account</a
        >
      </nav>
    </div>
  </header>
  <main
    class="mx-auto flex w-full max-w-3xl flex-1 flex-col justify-center px-4 py-20"
  >
    <p class="text-sm font-medium uppercase tracking-wider text-zinc-500">
      Astro · HTMX · Tailwind
    </p>
    <h1
      class="mt-3 text-4xl font-semibold tracking-tight text-foreground sm:text-5xl"
    >
      Hypermedia + Supabase + Stripe
    </h1>
    <p
      class="mt-6 max-w-xl text-lg leading-relaxed text-zinc-600 dark:text-zinc-400"
    >
      Clone this repo for each new project: server-rendered Astro pages, HTMX
      for login/checkout flows without a heavy client bundle, Postgres + RLS
      via Supabase, and Stripe Checkout with verified webhooks.
    </p>
    <ul class="mt-10 space-y-3 text-sm text-zinc-700 dark:text-zinc-300">
      <li class="flex gap-2">
        <span class="text-emerald-600 dark:text-emerald-400">✓</span>
        Magic-link auth and session refresh in middleware
      </li>
      <li class="flex gap-2">
        <span class="text-emerald-600 dark:text-emerald-400">✓</span>
        HTMX forms and <code class="text-xs">HX-Redirect</code> to Stripe
        Checkout
      </li>
      <li class="flex gap-2">
        <span class="text-emerald-600 dark:text-emerald-400">✓</span>
        Same security model: no raw card data, signed webhooks
      </li>
    </ul>
    <div class="mt-12 flex flex-wrap gap-3">
      <a
        href="/login"
        class="inline-flex items-center justify-center rounded-lg bg-foreground px-5 py-2.5 text-sm font-medium text-background transition hover:opacity-90"
        >Get started</a
      >
      <a
        href="https://docs.astro.build/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-lg border border-zinc-300 px-5 py-2.5 text-sm font-medium transition hover:bg-zinc-100 dark:border-zinc-600 dark:hover:bg-zinc-900"
        >Astro docs</a
      >
    </div>
  </main>
</Layout>
