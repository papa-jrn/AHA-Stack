# App URL (no trailing slash) — used for auth redirects and Stripe return URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: Stripe Dashboard → Webhooks → copy signing secret; required for /api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=

# Optional: Service role key — webhook uses this to record payments (bypasses RLS). Keep server-only.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe: Developers → API keys (never expose sk_ to the client)
STRIPE_SECRET_KEY=

# Stripe: Product → Price ID (price_...)
STRIPE_PRICE_ID=

# Optional: pk_ key for future Payment Element / client-side Stripe.js
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
